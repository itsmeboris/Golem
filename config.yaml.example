# Golem Configuration
# Copy this file to config.yaml and customize for your environment.
# Environment variables can be referenced as ${VAR_NAME}.

flows:
  golem:
    enabled: true

    # Profile: which backends to use for tasks, state, and notifications.
    # Built-in profiles:
    #   "local"   — file-based submissions, no external services
    #   "redmine" — Redmine issue tracking + Slack/Teams + MCP
    # For prompt-only mode, just use: golem run -p "your task here"
    profile: local
    # profile_config: {}          # profile-specific overrides

    # MCP servers: enable/disable all MCP tool servers
    mcp_enabled: false
    mcp_servers: []

    # Polling: detect [AGENT]-tagged issues in these projects
    projects:
      - my-project
    detection_tag: "[AGENT]"
    poll_interval: 120             # seconds between polls (daemon mode)
    tick_interval: 30              # seconds between ticks

    # Execution
    task_model: sonnet             # model for single-agent & Builder subagents
    task_timeout_seconds: 1800     # 30 min max per task
    budget_per_task_usd: 10.0      # 0 = unlimited
    max_active_sessions: 3

    # Validation (strong reasoning model reviews the work)
    validation_model: opus         # opus for strongest review
    validation_budget_usd: 0.50
    max_retries: 1                 # retry once on PARTIAL verdict
    auto_commit: true              # commit on PASS verdict

    # Subagent orchestration: single Claude session with Agent tool delegation
    supervisor_mode: true
    orchestrate_model: opus            # orchestrator needs strong planning
    orchestrate_budget_usd: 15.0
    orchestrate_timeout_seconds: 2400
    inner_retry_max: 3
    resume_on_partial: true

    # Working directories
    use_worktrees: true            # git worktree isolation per task
    default_work_dir: ""           # fallback CWD for agent
    work_dirs: {}                  # tag -> directory mapping
    #   MYPROJECT: /path/to/project

    # Checkpoint persistence (crash recovery)
    checkpoint_interval_seconds: 300   # seconds between checkpoint saves
    checkpoint_max_age_minutes: 10     # max age before checkpoint is stale

    # Prompt templates (override built-in prompts/ directory)
    # prompts_dir: ""

claude:
  cli_type: claude                 # "claude" or "agent"
  model: sonnet
  timeout_seconds: 1800
  max_concurrent: 5

dashboard:
  port: 8081
  # admin_token: ${DASHBOARD_ADMIN_TOKEN}
  # api_key: ${GOLEM_API_KEY}           # protects /api/submit endpoints; empty = open

# Notifications (enable one or neither; Slack takes priority if both enabled)
# Slack (Block Kit messages via incoming webhook)
slack:
  enabled: false
  # webhooks:
  #   golem: ${SLACK_GOLEM_WEBHOOK_URL}

# Teams (Adaptive Cards via incoming webhook)
teams:
  enabled: false
  # webhooks:
  #   golem: ${TEAMS_GOLEM_WEBHOOK_URL}

# Health monitoring & alerting
health:
  enabled: true
  check_interval_seconds: 60
  consecutive_failure_threshold: 3
  error_rate_threshold: 0.5
  error_rate_window_seconds: 900   # 15-minute time window
  error_rate_min_tasks: 4          # minimum tasks before evaluating
  queue_depth_threshold: 10
  stale_seconds: 3600
  alert_cooldown_seconds: 900
  disk_usage_threshold_gb: 0       # 0 = disabled

logging:
  log_level: INFO
  store_agent_traces: true
  store_thinking: false
