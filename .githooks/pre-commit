#!/bin/bash
# Pre-commit: auto-format with black, then lint with pylint --errors-only.
set -euo pipefail

# Use python3 if available, fall back to python
PYTHON="$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)"
if [[ -z "$PYTHON" ]]; then
    echo "pre-commit: no python interpreter found, skipping checks" >&2
    exit 0
fi

# Collect staged Python files (one per line, handles spaces in paths)
mapfile -t staged_py < <(git diff --cached --name-only --diff-filter=d -- '*.py' || true)
if [[ ${#staged_py[@]} -eq 0 || -z "${staged_py[0]}" ]]; then
    exit 0
fi

# ── black: auto-format and re-stage ──────────────────────────────────
if "$PYTHON" -m black --version >/dev/null 2>&1; then
    "$PYTHON" -m black --quiet "${staged_py[@]}"
    git add "${staged_py[@]}"
else
    echo "pre-commit: black not installed, skipping auto-format" >&2
fi

# ── pylint: block commit on errors ───────────────────────────────────
if "$PYTHON" -m pylint --version >/dev/null 2>&1; then
    if ! "$PYTHON" -m pylint --errors-only "${staged_py[@]}" 2>/dev/null; then
        echo "pre-commit: pylint found errors — fix before committing" >&2
        exit 1
    fi
else
    echo "pre-commit: pylint not installed, skipping error check" >&2
fi
