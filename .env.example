# Task Agent Environment Variables
# Copy this file to .env and fill in your values.
# These are loaded automatically by the agent at startup.

# --- Redmine (required for profile: redmine) ---
REDMINE_URL=https://redmine.example.com
REDMINE_API_KEY=your-redmine-api-key-here

# --- Teams Notifications (optional) ---
# TEAMS_TASK_AGENT_WEBHOOK_URL=https://outlook.office.com/webhook/...

# --- Dashboard ---
# DASHBOARD_ADMIN_TOKEN=my-secret-token
